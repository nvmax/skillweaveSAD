# ==============================================================================
# SkillWeave SAD — Provider and API Key Configuration
# ==============================================================================

# Provider choice: gemini | anthropic | openai | lmstudio | ollama
SKILLWEAVE_PROVIDER=lmstudio

# Model Selection:
# - LM Studio: (specify model identifier loaded in LM Studio, or leave blank to use the active loaded model)
# - Gemini:    gemini-2.5-pro | gemini-2.0-flash | gemini-1.5-pro
# - Anthropic: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# - OpenAI:    gpt-4o | gpt-4o-mini | o1-preview
# - Ollama:    llama3.1 | mistral | deepseek-coder
SKILLWEAVE_MODEL=gemma-4-31b-it

# API Keys (leave blank for local providers like LM Studio/Ollama)
SKILLWEAVE_API_KEY=

# Base URL (required for local/custom endpoints like LM Studio or Ollama)
# - LM Studio default: http://localhost:1234/v1
# - Ollama default:    http://localhost:11434/v1
SKILLWEAVE_BASE_URL=http://localhost:1234/v1

# SAD Pipeline Preferences
SKILLWEAVE_TEMPERATURE=0.1
SKILLWEAVE_MAX_TOKENS=8192
SKILLWEAVE_SKILL_INDEX_PATH=.agents/plugins/superpowers/skills/skill-index.json
SKILLWEAVE_SKILL_DAG_PATH=.agents/plugins/superpowers/skills/skill-dag.json
SKILLWEAVE_SKILL_LIBRARY_PATH=.agents/plugins/superpowers/library
